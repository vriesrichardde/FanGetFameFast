# Investigation working directories — never sync to GitHub
analysis/
reports/
vault/
graphify-out/
exports/
batch_work/

# Credentials and API keys
.env
*.env
.soc_env

# Claude Code local settings (machine-specific paths, MCP servers, credentials)
.claude/settings.local.json

# Claude Code runtime lock files (ephemeral process state)
.claude/*.lock

# Devcontainer personal config — generated from devcontainer.template.json, never committed
.devcontainer/devcontainer.json

# Python artifacts
.venv/
__pycache__/
*.py[cod]

# Forensic evidence files (safety net if evidence lands outside analysis/)
*.pcap
*.pcapng
*.mem
*.dmp
*.E01
*.vmdk
*.raw
*.dd
*.img
*.evtx

# Logs
*.log
