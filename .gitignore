# Investigation working directories — never sync to GitHub
analysis/
reports/
vault/
FAME-*/
FAST-*/
FAN-*/
graphify-out/
exports/
batch_work/
archive/

# Credentials and API keys
.env
*.env
.soc_env

# Claude Code local settings (machine-specific paths, MCP servers, credentials)
.claude/settings.local.json

# Claude Code runtime lock files (ephemeral process state)
.claude/*.lock

# Devcontainer: devcontainer.json uses ${localEnv:FGFF_EVIDENCE_INPUT} — set this
# env var to your local evidence directory before opening in a devcontainer.

# VS Code workspace settings — contains per-developer Claude Code permission config
.vscode/settings.json

# Python artifacts
.venv/
__pycache__/
*.py[cod]

# Forensic evidence files (safety net if evidence lands outside analysis/)
*.pcap
*.pcapng
*.mem
*.dmp
*.E01
*.vmdk
*.raw
*.dd
*.img
*.evtx

# macOS metadata
.DS_Store
**/.DS_Store

# Logs
*.log
